/ {
	amba_pl: amba_pl {
		ranges;
		compatible = "simple-bus";
		#address-cells = <1>;
		#size-cells = <1>;
		firmware-name = "zb_blinky_block3_wrapper.bit.bin";
		clocking0: clocking0 {
			compatible = "xlnx,fclk";
			assigned-clocks = <&clkc 15>;
			assigned-clock-rates = <100000000>;
			#clock-cells = <0>;
			clock-output-names = "fabric_clk";
			clocks = <&clkc 15>;
		};
		PmodCMPS2_0: PmodCMPS2@40000000 {
			compatible = "xlnx,PmodCMPS2-1.0";
			status = "okay";
			clock-names = "s_axi_aclk";
			xlnx,ip-name = "PmodCMPS2";
			xlnx,pmod = "Custom";
			xlnx,edk-iptype = "PERIPHERAL";
			reg = <0x40000000 0x1000>;
			clocks = <&clkc 15>;
			xlnx,name = "PmodCMPS2_0";
		};
		PmodESP32_0: PmodESP32@43c00000 {
			compatible = "xlnx,PmodESP32-1.0";
			status = "okay";
			clock-names = "s_axi_aclk";
			xlnx,ip-name = "PmodESP32";
			xlnx,pmod = "jc";
			xlnx,edk-iptype = "PERIPHERAL";
			reg = <0x43c00000 0x10000 0x43c10000 0x10000>;
			clocks = <&clkc 15>;
			xlnx,name = "PmodESP32_0";
		};
		axi_gpio_0: gpio@41200000 {
			xlnx,gpio-board-interface = "Custom";
			compatible = "xlnx,axi-gpio-2.0" , "xlnx,xps-gpio-1.00.a";
			xlnx,all-outputs = <0>;
			#gpio-cells = <2>;
			xlnx,gpio-width = <4>;
			xlnx,dout-default = <0x2>;
			xlnx,is-dual = <0>;
			xlnx,ip-name = "axi_gpio";
			xlnx,tri-default-2 = <0xffffffff>;
			reg = <0x41200000 0x10000>;
			xlnx,all-inputs-2 = <0>;
			clocks = <&clkc 15>;
			xlnx,all-outputs-2 = <0>;
			gpio-controller;
			xlnx,interrupt-present = <0>;
			xlnx,gpio2-board-interface = "Custom";
			xlnx,edk-iptype = "PERIPHERAL";
			xlnx,dout-default-2 = <0x0>;
			status = "okay";
			xlnx,gpio2-width = <32>;
			clock-names = "s_axi_aclk";
			xlnx,use-board-flow;
			xlnx,tri-default = <0xffffffff>;
			xlnx,name = "axi_gpio_0";
			xlnx,all-inputs = <0>;
		};
	};
};
